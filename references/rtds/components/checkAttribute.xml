    <!-- 2. EVALUATE: read the named session variable, compare, write __ca_result -->
    <object label="evaluate attribute" Type="script" OnEnter="" OnLeave="" DynamicNextId="" MaxEntryNodeId="" MaxEntryCount="" Code="var vars = context.session.variables; &#xa; &#xa;// Read component-internal params (__) &#xa;var sAttribute = vars.__ca_attribute; &#xa;var sOperator  = vars.__ca_operator; &#xa;var sValue     = vars.__ca_value; &#xa; &#xa;// Read the named session variable being tested, coerce to string &#xa;var sActual = vars[sAttribute]; &#xa;if (sActual === undefined || sActual === null) { &#xa;    sActual = ''; &#xa;} &#xa;sActual = String(sActual); &#xa; &#xa;// Attempt numeric coercion - use numeric comparison when both sides are valid numbers &#xa;var nActual  = parseFloat(sActual); &#xa;var nValue   = parseFloat(sValue); &#xa;var bNumeric = !isNaN(nActual) &amp;&amp; !isNaN(nValue); &#xa; &#xa;var bResult = false; &#xa; &#xa;if (sOperator === 'eq') { &#xa;    bResult = bNumeric ? (nActual === nValue) : (sActual === sValue); &#xa;} else if (sOperator === 'ne') { &#xa;    bResult = bNumeric ? (nActual !== nValue) : (sActual !== sValue); &#xa;} else if (sOperator === 'gt') { &#xa;    bResult = bNumeric &amp;&amp; (nActual &gt; nValue); &#xa;} else if (sOperator === 'ge') { &#xa;    bResult = bNumeric &amp;&amp; (nActual &gt;= nValue); &#xa;} else if (sOperator === 'lt') { &#xa;    bResult = bNumeric &amp;&amp; (nActual &lt; nValue); &#xa;} else if (sOperator === 'le') { &#xa;    bResult = bNumeric &amp;&amp; (nActual &lt;= nValue); &#xa;} else if (sOperator === 'contains') { &#xa;    bResult = sActual.indexOf(sValue) !== -1; &#xa;} else if (sOperator === 'startswith') { &#xa;    bResult = sActual.indexOf(sValue) === 0; &#xa;} else if (sOperator === 'empty') { &#xa;    bResult = sActual.length === 0; &#xa;} else if (sOperator === 'notempty') { &#xa;    bResult = sActual.length &gt; 0; &#xa;} else { &#xa;    log_warn('[RTDS] checkAttribute: unknown operator=' + sOperator + ' - defaulting to false'); &#xa;    bResult = false; &#xa;} &#xa; &#xa;// Write result to component-internal session var (__ prefix) &#xa;vars.__ca_result = bResult ? '1' : '0'; &#xa; &#xa;log_debug('[RTDS] checkAttribute: ' + sAttribute + '(' + sActual + ') ' + sOperator + ' ' + sValue + ' =&gt; ' + (bResult ? 'true' : 'false'));" DynamicNextTabGuid="" id="n-evaluate">
