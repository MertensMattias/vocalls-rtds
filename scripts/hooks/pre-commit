#!/bin/sh
# vocalls-rtds pre-commit hook — block commits that introduce drift.
#
# Runs the same gate as `npm run check`: skill-bundle sync, lockstep contract
# check, and the Jest suite. Install once with:
#
#     sh scripts/hooks/install.sh
#
# To bypass in an emergency (discouraged): git commit --no-verify
set -e

echo "[pre-commit] running npm run check ..."
npm run check
echo "[pre-commit] OK"
