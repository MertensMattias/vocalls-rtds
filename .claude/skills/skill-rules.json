            ],
            "intentPatterns": [
                "(build|generate|create).*CONFIG",
                "(translate|convert).*scenario.*CONFIG",
                "config.*builder"
            ]
        }
    },
    "vocalls-prompt-validator": {
        "type": "domain",
        "enforcement": "suggest",
        "priority": "high",
        "promptTriggers": {
            "keywords": [
                "prompt validator",
                "validate CONFIG",
                "run checks",
                "vocalls validate",
                "review CONFIG",
                "validation report"
            ],
            "intentPatterns": [
                "(validate|check|review).*CONFIG",
                "(run|execute).*validation",
                "prompt.*validator"
