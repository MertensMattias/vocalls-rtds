    "vocalls-translator": {
        "type": "domain",
        "enforcement": "suggest",
        "priority": "high",
        "promptTriggers": {
            "keywords": [
                "translator agent",
                "translate CONFIG",
                "fill language slots",
                "vocalls translate",
