            ],
            "intentPatterns": [
                "(translate|fill).*language",
                "(translate|localize).*CONFIG",
                "translator.*agent"
            ]
        }
    },
    "vocalls-brief": {
        "type": "domain",
        "enforcement": "suggest",
        "priority": "high",
        "promptTriggers": {
            "keywords": [
                "vocalls-brief",
                "generate brief",
                "brief from visio",
                "brief from pdf",
                "extract brief",
                "draft brief",
                "create brief from",
                "brief from diagram"
            ],
            "intentPatterns": [
                "(generate|create|draft|extract).*brief",
                "brief.*from.*(visio|pdf|diagram|vsdx)",
