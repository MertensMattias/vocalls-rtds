{
    "vocalls-build": {
        "type": "domain",
        "enforcement": "suggest",
        "priority": "high",
        "promptTriggers": {
            "keywords": [
                "vocalls-build",
                "build pipeline",
                "run pipeline",
                "generate CONFIG",
                "resume pipeline",
                "/vocalls-build"
            ],
            "intentPatterns": [
                "(run|start|resume|execute).*pipeline",
                "(build|generate).*CONFIG",
                "vocalls.*(build|pipeline)"
            ]
        }
    },
    "vocalls-intake": {
        "type": "domain",
        "enforcement": "suggest",
        "priority": "high",
        "promptTriggers": {
            "keywords": [
                "intake agent",
                "parse brief",
                "extract cases",
                "normalize inventory",
                "vocalls intake",
                "business brief"
            ],
            "intentPatterns": [
                "(parse|process|read).*brief",
                "(extract|identify).*cases",
                "intake.*agent"
            ]
        }
    },
    "vocalls-scenario-designer": {
        "type": "domain",
        "enforcement": "suggest",
        "priority": "high",
        "promptTriggers": {
            "keywords": [
                "scenario designer",
                "design scenarios",
                "conversational logic",
                "vocalls scenario",
                "scenario design"
            ],
            "intentPatterns": [
                "(design|create).*scenario",
                "(transform|convert).*intake.*scenario",
                "scenario.*design"
            ]
        }
    },
    "vocalls-config-builder": {
        "type": "domain",
        "enforcement": "suggest",
        "priority": "high",
        "promptTriggers": {
